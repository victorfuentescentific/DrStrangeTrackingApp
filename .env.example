# ── Authentication ────────────────────────────────────────────────────────────
# Random secret used to sign JWT session tokens.
# Generate one with: openssl rand -base64 32
AUTH_SECRET=your-random-secret-here

# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in: Supabase dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── AI Assistant (Gemini) ─────────────────────────────────────────────────────
# Free-tier key from Google AI Studio: https://aistudio.google.com → Get API key.
# Used by /api/ai/chat to power the AI Assistant page. Server-side only —
# never prefix with NEXT_PUBLIC_, the key must not be exposed to the browser.
GEMINI_API_KEY=your-gemini-api-key-here

# ── Confluence link (optional) ────────────────────────────────────────────────
# Points the "Open Confluence" button on /notes to your team's space.
# NEXT_PUBLIC_CONFLUENCE_URL=https://your-org.atlassian.net/wiki/spaces/YOURSPACE

# ── Vercel ────────────────────────────────────────────────────────────────────
# No PORT variable needed — Vercel runs Next.js as serverless functions.
# Set AUTH_SECRET, SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY, and GEMINI_API_KEY in:
# Vercel dashboard → Project → Settings → Environment Variables
# Make sure to set them for both "Production" and "Preview" environments.
