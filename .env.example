# ── Authentication ────────────────────────────────────────────────────────────
# Random secret used to sign JWT session tokens.
# Generate one with: openssl rand -base64 32
AUTH_SECRET=your-random-secret-here

# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in: Supabase dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Vercel ────────────────────────────────────────────────────────────────────
# No PORT variable needed — Vercel runs Next.js as serverless functions.
# Set AUTH_SECRET, SUPABASE_URL, and SUPABASE_SERVICE_ROLE_KEY in:
# Vercel dashboard → Project → Settings → Environment Variables
# Make sure to set them for both "Production" and "Preview" environments.
